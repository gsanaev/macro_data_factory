# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

cat >> .gitignore <<'EOF'

# Downloaded source data
data/raw/**
!data/raw/.gitkeep
EOF

# Interim and processed data
data/interim/**
!data/interim/.gitkeep
data/processed/**
!data/processed/.gitkeep
data/releases/**
!data/releases/.gitkeep